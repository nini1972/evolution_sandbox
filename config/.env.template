# LLM Provider Configuration
# We will use OpenRouter via litellm.
# Create a file named .env and put your OpenRouter API key here.

OPENROUTER_API_KEY="your-openrouter-key-here"

# Default Model to use for the agent
# Example: "openrouter/anthropic/claude-3.5-sonnet", "openrouter/google/gemini-1.5-pro"
AGENT_MODEL="openrouter/google/gemini-1.5-pro"
